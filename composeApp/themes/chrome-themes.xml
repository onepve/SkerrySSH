        <color name="line" over="white" alpha="0.06"/>
        <color name="lineStrong" over="white" alpha="0.14"/>
        <!-- Shared surfaces / accents -->
        <color name="strictFg">#E06A5A</color>
        <color name="whiteFaint">#1AFFFFFF</color>
        <color name="ink">#071A12</color>            <!-- deep green-black on the green accent buttons -->
        <color name="card">#08FFFFFF</color>
        <color name="scrim">#B3050816</color>
        <color name="modalScrim">#B30C0E1B</color>
        <color name="overlayFaint" over="white" alpha="0.02"/>
        <color name="overlaySoft" over="white" alpha="0.04"/>
