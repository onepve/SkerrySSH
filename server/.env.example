# Skerry Sync — 服务器配置（单 .env 模式）。复制为 .env 并按需填写。
# 除 SKERRY_JWT_SECRET 在生产环境必须设置外，所有变量均可选。

# 网络接口和端口。服务器使用明文 HTTP —— 在外部可达的部署前需要加 TLS 反向代理
#（Caddy/nginx/Traefik）。详见 SECURITY.md。
SKERRY_HOST=0.0.0.0
SKERRY_PORT=8080
# 服务器公网域名（含协议），用于邮件中的链接和首页展示。不设则留空。
# 示例: https://example.com
SKERRY_PUBLIC_URL=

# 反向代理配置。逗号分隔的可信代理 IP 白名单（服务器前面的直接对端）。
# 请求来自这些 IP 时，每 IP 速率限制以 X-Forwarded-For 中的真实客户端 IP 为键；
# 否则忽略该头（客户端无法伪造以绕过限制）。空 → 无代理，以直接连接为键。
# 仅列出会 追加/覆盖 X-Forwarded-For 的代理（nginx 的 $proxy_add_x_forwarded_for，
# Caddy/Traefik 默认）。如果代理透传客户端头未经修改，后面的客户端可伪造整条链绕过限制。
SKERRY_TRUSTED_PROXIES=

# 注册控制。\"open\" → POST /auth/register 接受新账户；
# \"closed\" → 返回 403（已有账户仍可登录和配对新设备）。
# 部署时先开放，注册完账户后关闭。默认：open。
SKERRY_REGISTRATION=open
# 可选账户总数硬限制（"忘记关闭"的兜底）。0 → 无限制。
SKERRY_MAX_ACCOUNTS=0
# 注册是否需要邀请码。true → 新注册必须提供有效邀请码（与 SKERRY_REGISTRATION 独立，
# "open"时也可强制邀请码）。已有账户登录/配对新设备不受此限制。默认：false。
SKERRY_INVITE_REQUIRED=false

# 存储。默认使用 SQLite（无需用户名密码）；切换 PostgreSQL 时取消下面的注释并填写。
SKERRY_DB_URL=jdbc:sqlite:skerry-sync.db
# SKERRY_DB_URL=jdbc:postgresql://localhost:5432/skerry
# 以下两项仅 PostgreSQL 需要（SQLite 忽略）
SKERRY_DB_USER=
SKERRY_DB_PASSWORD=

# JWT 签名。生产环境务必设置一个长随机密钥：
#   openssl rand -base64 48
# 轮换密钥会作废所有已颁发的令牌。
SKERRY_JWT_SECRET=dev-insecure-change-me
SKERRY_JWT_ISSUER=skerry-sync

# 令牌和配对会话生命周期（秒）。
SKERRY_ACCESS_TTL=900
SKERRY_REFRESH_TTL=2592000
SKERRY_PAIRING_TTL=300

# 墓碑记录保留天数。设备被吊销后相关记录保留此天数后才清理。
SKERRY_TOMBSTONE_DAYS=90
# 账号活动日志保留天数。
SKERRY_ACTIVITY_RETENTION_DAYS=30
# 活动日志最大行数（超出后裁剪旧记录）。
SKERRY_ACTIVITY_MAX_ROWS=10000

# 管理控制台令牌。为空 → 管理端点关闭。
SKERRY_ADMIN_TOKEN=

# 管理后台访问路径（默认 /console）。
SKERRY_CONSOLE_PATH=/console

# 仅本地开发：SKERRY_DEV=1 解除默认 JWT 密钥的启动拦截。
# 生产环境必须设置真实的 SKERRY_JWT_SECRET。
SKERRY_DEV=

# 允许的 CORS 来源，逗号分隔，例如 https://app.example.com。
# 为空则禁用 CORS（原生客户端不受同源限制）。
SKERRY_CORS_HOSTS=
# 请求体大小上限（字节）。默认 4 MiB。
SKERRY_MAX_BODY_BYTES=4194304

# ===== 邮件通知 =====
# 启用后，注册、新设备配对、密码变更、可疑登录会发送通知邮件。
SKERRY_MAIL_ENABLED=false
# SMTP 服务器地址
SKERRY_MAIL_HOST=
# SMTP 端口（465=SMTPS 隐式TLS，587=STARTTLS）
SKERRY_MAIL_PORT=587
# SMTP 认证用户名
SKERRY_MAIL_USER=
# SMTP 认证密码
SKERRY_MAIL_PASSWORD=
# 发件人地址，格式："名称 <邮箱>"
SKERRY_MAIL_FROM=Skerry <noreply@ssh.example.com>
# 启用 TLS 加密
SKERRY_MAIL_TLS=true
# 邮件模板配置文件路径（品牌名、标题等），与数据库同目录
SKERRY_MAIL_CONFIG_PATH=/data/mail-config.json
