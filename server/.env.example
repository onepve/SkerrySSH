# Skerry Sync — server configuration (single-.env model). Copy to .env and fill in.
# All values are optional except SKERRY_JWT_SECRET in production.

# Network interface and port. The server speaks plain HTTP — put a TLS reverse proxy
# (Caddy/nginx/Traefik) in front of it for anything reachable off the host. See SECURITY.md.
SKERRY_HOST=0.0.0.0
SKERRY_PORT=8080

# Reverse-proxy topology. Comma-separated allowlist of trusted proxy IPs (the direct peers
# in front of the server). When the request arrives from one of these, per-IP rate limits key
# on the real client IP from X-Forwarded-For; otherwise the header is ignored (a client can't
# spoof it to dodge limits). Empty ⇒ no proxy, key on the direct connection.
# Only list a proxy that APPENDS/OVERWRITES X-Forwarded-For with the peer it actually saw
# (nginx's $proxy_add_x_forwarded_for, Caddy/Traefik defaults). A proxy that passes the client's
# header through untouched lets a client behind it forge the whole chain and evade the limit.
SKERRY_TRUSTED_PROXIES=

# Registration control (Vaultwarden's SIGNUPS_ALLOWED model). "open" ⇒ POST /auth/register
# accepts new accounts; "closed" ⇒ it returns 403 (existing accounts still log in and pair new
# devices). Deploy open, register your accounts, then set closed. Default: open.
SKERRY_REGISTRATION=open
# Optional hard cap on total accounts (backstop for "left open"). 0 ⇒ unlimited.
SKERRY_MAX_ACCOUNTS=0

# Storage. SQLite file by default; for PostgreSQL replace the URL and set user/password.
SKERRY_DB_URL=jdbc:sqlite:skerry-sync.db
# SKERRY_DB_URL=jdbc:postgresql://localhost:5432/skerry
SKERRY_DB_USER=
SKERRY_DB_PASSWORD=

# JWT signing. REQUIRED: set a long random secret in production:
#   openssl rand -base64 48
# Rotating the secret invalidates all issued tokens.
SKERRY_JWT_SECRET=dev-insecure-change-me
SKERRY_JWT_ISSUER=skerry-sync

# Token and pairing-session lifetimes (seconds).
SKERRY_ACCESS_TTL=900
SKERRY_REFRESH_TTL=2592000
SKERRY_PAIRING_TTL=300

# Tombstone retention (days).
SKERRY_TOMBSTONE_DAYS=90

# Admin console token (/console and /admin/stats). Empty ⇒ stats endpoints are closed.
SKERRY_ADMIN_TOKEN=

# Local development only: SKERRY_DEV=1 lifts the fail-fast guard on the default
# JWT secret. Production must set a real SKERRY_JWT_SECRET instead.
SKERRY_DEV=

# Allowed CORS origins, comma-separated, e.g. https://app.example.com.
# A scheme prefix narrows the origin to that scheme; a bare host allows http and https.
# "*" allows any origin (disables the allow-list) — avoid it in production.
# Empty disables CORS (native clients aren't subject to same-origin anyway).
SKERRY_CORS_HOSTS=
