# Local working notes — never committed
*.local.md

# Gradle
.gradle/
build/
**/build/

# Kotlin/Native, KMP
.kotlin/

# IDE
.idea/
*.iml
.vscode/
local.properties

# Xcode / iOS
*.xcworkspace/xcuserdata/
**/xcuserdata/
iosApp/Pods/
DerivedData/

# OS
.DS_Store
Thumbs.db

# Signing secrets — never commit (the release keystore comes from GH Secrets)
*.jks
*.keystore
keystore.properties

# Server secrets — .env holds the JWT secret, DB password and admin token
# (server/.env.example is the committed template; the filled-in .env never is).
.env
.env.*
!.env.example
server/.env

# Logs and temporary files
*.log
*.hprof

# Local SQLite files of the sync server
*.db
*.db-journal
.tokensave

# Flatpak build outputs (the committed inputs are the manifest + flatpak-sources.json)
composeApp/flatpak/.build/
composeApp/flatpak/*.flatpak
